{
  "name": "act-trading-desktop",
  "version": "1.0.0",
  "description": "ACT Trading — Algorithmic Crypto Trading Desktop",
  "private": true,
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "unset ELECTRON_RUN_AS_NODE && vite",
    "build": "vue-tsc -b && vite build && electron-builder",
    "build:unpack": "vue-tsc -b && vite build && electron-builder --dir",
    "preview": "vite preview",
    "electron:dev": "vite"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2",
    "electron-store": "^8.2.0",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^3.2.5"
  }
}
